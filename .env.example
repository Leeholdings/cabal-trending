# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Channel ID where alerts are posted (negative number starting with -100 for channels).
# After creating bot + channel + adding bot as admin + posting any message,
# run: npm run get-chat-id
TELEGRAM_CHAT_ID=

# --- Polling ---
# Seconds between scanner polls. 15-30 is the recommended range.
POLL_INTERVAL_SECONDS=20

# --- DexScreener ---
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# --- Chain ---
# Only 'solana' is supported in this version. The architecture allows future
# chain additions but the runtime rejects non-Solana inputs.
CHAIN_ID=solana

# --- Local DB ---
DB_PATH=data/cabal.sqlite

# --- Logging ---
LOG_LEVEL=info
